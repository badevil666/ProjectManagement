# Base URL of the backend API, including the /api prefix.
#
# - Local dev (frontend on 5173, backend on 4000): http://localhost:4000/api
# - Docker Compose: leave unset / empty at build time — nginx proxies
#   /api/* to the `backend` service inside the compose network, so the app
#   can call same-origin relative "/api" paths instead.
# - Split hosting (e.g. Vercel frontend + Render backend): set this to the
#   fully-qualified backend URL, e.g. https://client-portal-api.onrender.com/api
#
# Read at build time via import.meta.env.VITE_API_URL, falls back to
# "http://localhost:4000/api" if unset.
VITE_API_URL=http://localhost:4000/api
