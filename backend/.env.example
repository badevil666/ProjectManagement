# ---------------------------------------------------------------------------
# Client Portal backend — environment variables
# Copy this file to `.env` and fill in real values for local development.
# Every variable listed here is actually read by the code (config/env.ts).
# ---------------------------------------------------------------------------

# Node environment: development | production | test
NODE_ENV=development

# Port the Express server listens on.
PORT=4000

# PostgreSQL connection string used by Prisma.
# Local docker-compose default shown; database name must be `client_portal`.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/client_portal?schema=public"

# Comma-separated allow-list of origins permitted by CORS.
# Must include the Vite dev server origin locally.
CORS_ORIGIN="http://localhost:5173"

# JWT signing secret (use a long random string in production) and expiry.
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Directory (relative or absolute) where uploaded files are stored on disk
# by the LocalStorageService. Defaults to ./uploads if unset.
UPLOAD_DIR="./uploads"

# --- SMTP / Nodemailer (Gmail SMTP recommended) -----------------------------
# All four are optional in development: if any are missing, the
# NotificationService logs emails to the console instead of sending them.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-gmail-address@gmail.com"
SMTP_PASS="your-gmail-app-password"
SMTP_FROM="Client Portal <no-reply@example.com>"

# --- Seed script only (backend/prisma/seed.ts) ------------------------------
# Not read by the running server — only validated/consumed when seeding.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_NAME="Admin User"
